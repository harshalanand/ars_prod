# ==========================================================================
# ARS Backend — Environment Variables
# Copy this to .env and fill in actual values. NEVER commit .env to git.
# ==========================================================================

APP_ENV=development
DEBUG=false

# --- Database ---
# Local:
DB_SERVER=HOPC560
DB_USERNAME=sa
DB_PASSWORD=vrl@55555
DB_TRUST_CERT=yes
DB_ENCRYPT=no
# Azure SQL (uncomment for cloud):
# DB_SERVER=ars-sql-server.database.windows.net
# DB_USERNAME=arsadmin
# DB_PASSWORD=YourStrongPassword
# DB_TRUST_CERT=no
# DB_ENCRYPT=yes

DB_NAME=Claude
DATA_DB_NAME=Rep_data
DB_POOL_SIZE=15
DB_MAX_OVERFLOW=25
DB_POOL_RECYCLE=300

# --- JWT ---
# Generate: python -c "import secrets; print(secrets.token_urlsafe(64))"
JWT_SECRET_KEY=your-super-secret-key-change-in-production-min-32-chars

# --- CORS ---
CORS_ORIGINS=["http://localhost:3000","http://localhost:8000"]
# Production: CORS_ORIGINS=["https://ars.v2retail.net"]

# --- Storage ---
USE_BLOB_STORAGE=false
# AZURE_STORAGE_CONNECTION_STRING=DefaultEndpointsProtocol=https;AccountName=...
# AZURE_STORAGE_CONTAINER=ars-files

# --- Admin ---
SUPER_ADMIN_USERNAME=superadmin
SUPER_ADMIN_EMAIL=admin@nubo.in
SUPER_ADMIN_PASSWORD=Admin@12345

# --- Logging ---
LOG_LEVEL=INFO
LOG_TO_FILE=true
